# Estrich Digital – Apache Konfiguration

# Fehlerseiten
ErrorDocument 404 /index.php

# www weiterleiten auf non-www
RewriteEngine On
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^ http://%1%{REQUEST_URI} [R=301,L]

# News-URLs – SEO-freundliche Einzelansicht
# /news           → Übersicht (pages/news.php)
# /news/<slug>    → Detail-Seite (pages/news-detail.php?slug=...)
RewriteRule ^news/?$ pages/news.php [L,QSA]
RewriteRule ^news/([^/]+)/?$ pages/news-detail.php?slug=$1 [L,QSA]

# HTTPS-Redirect deaktiviert – Homepage hat (noch) kein eigenes SSL-Zertifikat
# RewriteCond %{HTTPS} off
# RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# Verzeichnis-Listings deaktivieren
Options -Indexes

# Gzip-Komprimierung
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript image/svg+xml text/plain
</IfModule>

# Browser-Caching
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType image/png "access plus 6 months"
  ExpiresByType image/jpg "access plus 6 months"
  ExpiresByType image/jpeg "access plus 6 months"
  ExpiresByType image/svg+xml "access plus 6 months"
</IfModule>

# Sicherheits-Header
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
